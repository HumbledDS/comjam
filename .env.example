# Cal.com — used by /reservation page to embed booking calendar
# Create a free account at cal.com, then create one event type per pack
# and put your username here (e.g. "comjam"). Booking links become cal.com/<username>/<event>
NEXT_PUBLIC_CAL_USERNAME=

# PayPal.me — used to generate payment links from /reservation
# Get your handle at paypal.me. Just the handle, no slash or URL (e.g. "comjam")
NEXT_PUBLIC_PAYPAL_HANDLE=

# Resend — optional, for the /contact form. Without this, submissions hit a
# console-log stub in /api/contact/route.ts. Get a key at resend.com.
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@comjam.fr
CONTACT_FROM_EMAIL=Com'Jam <hello@comjam.fr>
