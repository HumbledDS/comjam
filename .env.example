# ============================================================
# LAUNCH FLAG
# ============================================================
# Set to "true" on launch day. While unset (or anything other than "true"):
#   - The homepage renders the ComingSoon page
#   - Nav and Footer are hidden site-wide
#   - Middleware redirects every other route back to "/"
# Once set to "true" and redeployed, the full site is visible.
NEXT_PUBLIC_LAUNCHED=

# ============================================================
# CONTACT FORM (Resend) — REQUIRED for the contact form to actually send mail
# ============================================================
# 1. Create a free Resend account at https://resend.com
# 2. Add and verify the comjam.fr domain (Settings → Domains).
#    Until verified, you can use "onboarding@resend.dev" as the from address
#    for testing, but it will land in spam.
# 3. Create an API key (Settings → API Keys) and paste below.
# 4. Set CONTACT_FROM_EMAIL to an address on your verified domain.
# 5. Set CONTACT_TO_EMAIL to where messages should be delivered.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Com'Jam <hello@comjam.fr>
CONTACT_TO_EMAIL=contact@comjam.fr

# ============================================================
# BOOKING (Cal.com) — optional, /reservation falls back to a "demander des dates"
# CTA when these are empty.
# ============================================================
# Your Cal.com username (cal.com/<username>). Create one event type per pack
# (slugs: flash-1h, signature, duo, reel-video) — see lib/copy.ts.
NEXT_PUBLIC_CAL_USERNAME=

# ============================================================
# PAYMENT (PayPal.me) — optional, deposit link hides when empty.
# Just the handle, no slash or URL (e.g. "comjam").
# ============================================================
NEXT_PUBLIC_PAYPAL_HANDLE=
